{

  "name": "@workspace/pharmacist-pmr",

  "version": "1.0.0",

  "private": true,

  "type": "module",

  "main": "electron/main.cjs",

  "description": "EveryDayMeds PMR — Windows desktop dispensing with barcode scan and label printing",

  "author": "EveryDayMeds",

  "scripts": {

    "dev": "vite --config vite.config.ts --host 0.0.0.0",

    "dev:web": "vite --config vite.config.ts --host 0.0.0.0",

    "dev:desktop": "concurrently -k \"vite --config vite.config.ts --host 0.0.0.0\" \"wait-on http://localhost:5175 && cross-env VITE_DEV_SERVER_URL=http://localhost:5175 electron electron/main.cjs\"",

    "build": "vite build --config vite.config.ts",

    "build:desktop": "vite build --config vite.config.ts && electron-builder --win",

    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",

    "typecheck": "tsc -p tsconfig.json --noEmit"

  },

  "build": {

    "appId": "com.everydaymeds.pmr",

    "productName": "EveryDayMeds PMR",

    "directories": {

      "output": "release"

    },

    "files": [

      "dist/public/**/*",

      "electron/**/*",

      "package.json"

    ],

    "win": {

      "target": [

        "nsis"

      ]

    },

    "nsis": {

      "oneClick": false,

      "allowToChangeInstallationDirectory": true,

      "shortcutName": "EveryDayMeds PMR"

    }

  },

  "devDependencies": {

    "@radix-ui/react-dialog": "^1.1.7",

    "@radix-ui/react-dropdown-menu": "^2.1.7",

    "@radix-ui/react-label": "^2.1.3",

    "@radix-ui/react-popover": "^1.1.7",

    "@radix-ui/react-slot": "^1.2.0",

    "@radix-ui/react-toast": "^1.2.7",

    "@radix-ui/react-tooltip": "^1.2.0",

    "@replit/vite-plugin-cartographer": "catalog:",

    "@replit/vite-plugin-dev-banner": "catalog:",

    "@replit/vite-plugin-runtime-error-modal": "catalog:",

    "@tailwindcss/vite": "catalog:",

    "@tanstack/react-query": "catalog:",

    "@types/node": "catalog:",

    "@types/react": "catalog:",

    "@types/react-dom": "catalog:",

    "@vitejs/plugin-react": "catalog:",

    "@workspace/api-client-react": "workspace:*",

    "class-variance-authority": "catalog:",

    "clsx": "catalog:",

    "cmdk": "^1.1.1",

    "concurrently": "^9.2.1",

    "cross-env": "^7.0.3",

    "electron": "^35.7.5",

    "electron-builder": "^26.0.12",

    "lucide-react": "catalog:",

    "react": "catalog:",

    "react-dom": "catalog:",

    "tailwind-merge": "catalog:",

    "tailwindcss": "catalog:",

    "tw-animate-css": "^1.4.0",

    "vite": "catalog:",

    "wait-on": "^8.0.5",

    "wouter": "^3.3.5"

  }

}

