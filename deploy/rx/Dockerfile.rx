# PharmaCare Rx portal — static build + nginx
FROM node:24-alpine AS build
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
ENV VITE_API_BASE_URL=
ENV BASE_PATH=/
RUN pnpm --filter @workspace/pharmacist-rx run build

FROM nginx:alpine
COPY deploy/rx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/artifacts/pharmacist-rx/dist/public /usr/share/nginx/html
EXPOSE 80
